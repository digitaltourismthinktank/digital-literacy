---
import { getCollection } from 'astro:content';
import Shell from '../../layouts/Shell.astro';
import { getModuleData } from '../../data/index';
import Frames41 from '../../components/modules/Frames41.astro';
import Frames42 from '../../components/modules/Frames42.astro';
import Frames43 from '../../components/modules/Frames43.astro';
import Frames44 from '../../components/modules/Frames44.astro';
import Frames45 from '../../components/modules/Frames45.astro';
import Frames46 from '../../components/modules/Frames46.astro';

export async function getStaticPaths() {
  const modules = await getCollection('modules');
  return modules.map((mod) => ({
    params: { id: mod.id },
    props: { meta: mod.data },
  }));
}

interface Props {
  meta: {
    track: number;
    trackName: string;
    title: string;
    hook: string;
    duration?: string;
    isFree: boolean;
    status: 'published' | 'coming-soon';
    prev: string | null;
    next: string | null;
  };
}

const { id } = Astro.params;
const { meta } = Astro.props;
const displayId = id.replace('-', '.');
const data = getModuleData(id);
---

<Shell title={`Module ${displayId} — ${meta.title}`} moduleId={id}>

  {meta.status === 'coming-soon' && (
    <div class="lesson-wrap">
      <div class="coming-soon">
        <div class="cs-track">Track {meta.track} · {meta.trackName}</div>
        <h1>{meta.title}</h1>
        <p>{meta.hook}</p>
        <a href="/" class="cs-back">← Back to overview</a>
      </div>
    </div>
  )}

  {meta.status === 'published' && data && (
    <div class="lesson-wrap">
      <main class="lesson" data-module-id={id} aria-label={`Module ${displayId} lesson`}>

        <div class="topbar">
          <span class="crumb">Module&nbsp;<b>{displayId}</b> · Track {meta.track} {meta.trackName}</span>
          <div class="segments" id="segments" aria-hidden="true"></div>
          <span class="timehint" id="timehint">{meta.duration}</span>
        </div>

        <div class="stage" id="stage">
          {id === '4-1' && <Frames41 data={data} />}
          {id === '4-2' && <Frames42 data={data} />}
          {id === '4-3' && <Frames43 data={data} />}
          {id === '4-4' && <Frames44 data={data} />}
          {id === '4-5' && <Frames45 data={data} />}
          {id === '4-6' && <Frames46 data={data} />}
        </div>

        <div class="controls">
          <button class="btn ghost" id="backBtn" disabled>← Back</button>
          <button class="btn primary" id="nextBtn">Start →</button>
        </div>

      </main>
    </div>
  )}

  <script is:inline>
  (function () {
    var TOTAL   = document.querySelectorAll('.frame').length;
    if (!TOTAL) return;
    var frame   = 0;
    var frames  = Array.prototype.slice.call(document.querySelectorAll('.frame'));
    var segWrap = document.getElementById('segments');
    var backBtn = document.getElementById('backBtn');
    var nextBtn = document.getElementById('nextBtn');
    var mainEl  = document.querySelector('.lesson[data-module-id]');
    var modId   = mainEl ? mainEl.dataset.moduleId : '';

    for (var i = 0; i < TOTAL; i++) {
      var s = document.createElement('div');
      s.className = 'seg';
      segWrap.appendChild(s);
    }
    var segs = Array.prototype.slice.call(segWrap.children);

    var PK = 'dl_progress';
    function pRead() { try { return JSON.parse(localStorage.getItem(PK) || '{}'); } catch (e) { return {}; } }
    function pWrite(m) {
      try { localStorage.setItem(PK, JSON.stringify(m)); } catch (e) {}
      if (typeof window.__msWriteProgress === 'function') window.__msWriteProgress();
    }

    function render() {
      frames.forEach(function (f) { f.classList.toggle('show', +f.dataset.frame === frame); });
      segs.forEach(function (s, i) {
        s.className = 'seg' + (i < frame ? ' done' : '') + (i === frame ? ' active' : '');
      });
      backBtn.disabled = frame === 0;
      nextBtn.textContent = frame === 0 ? 'Start →' : (frame === TOTAL - 1 ? 'Finish' : 'Next →');
      nextBtn.disabled = frame === TOTAL - 1;
      var active = frames[frame];
      var h = active ? active.querySelector('h1,h2') : null;
      if (h) { h.setAttribute('tabindex', '-1'); h.focus({ preventScroll: true }); }
    }

    function go(n) {
      frame = Math.max(0, Math.min(TOTAL - 1, n));
      var m   = pRead();
      var cur = m[modId] || { complete: false, furthest: 0 };
      if (frame > cur.furthest) {
        m[modId] = Object.assign({}, cur, { furthest: frame });
        pWrite(m);
      }
      render();
    }

    backBtn.onclick = function () { go(frame - 1); };
    nextBtn.onclick = function () { go(frame + 1); };
    document.addEventListener('keydown', function (e) {
      if (e.target.matches('input,textarea,button,summary,[contenteditable]') &&
          (e.key === 'Enter' || e.key === ' ')) return;
      if (e.key === 'ArrowRight') go(frame + 1);
      if (e.key === 'ArrowLeft')  go(frame - 1);
    });

    render();
  })();
  </script>

</Shell>
